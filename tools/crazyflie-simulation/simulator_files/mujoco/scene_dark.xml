<mujoco model="Dark drone scene">
  <option integrator="RK4" density="1.225" viscosity="1.8e-5" timestep="0.001"/>
  <compiler inertiafromgeom="false" autolimits="true"/>
  <statistic center="0 0 2" extent="2.5"/>

  <visual>
    <headlight diffuse="0 0 0" ambient="0 0 0" specular="0 0 0"/>
    <rgba haze="0 0 0 0" fog="0 0 0 0"/>
    <map fogstart="0" fogend="0"/>
    <global azimuth="0" elevation="-20" ellipsoidinertia="true"/>
    <quality shadowsize="4096"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.01 0.01 0.02" rgb2="0 0 0"
             width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge"
             rgb1="0.15 0.15 0.15" rgb2="0.1 0.1 0.1"
             markrgb="0.2 0.2 0.2" width="512" height="512"/>
    <material name="groundplane" texture="groundplane" texuniform="true"
              texrepeat="2 2" reflectance="0.3"/>
  </asset>

  <worldbody>
    <!-- Very dim ambient fill, no shadows so drone body doesn't block it -->
    <light pos="0 0 3" dir="0 0 -1" directional="true" castshadow="false"
           diffuse="0.02 0.02 0.025" specular="0 0 0" ambient="0.01 0.01 0.01"/>
    <geom name="floor" size="0 0 0.05" type="plane" material="groundplane"/>
  </worldbody>

</mujoco>
